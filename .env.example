TRYON_PROVIDER=fashn
FASHN_API_KEY=
# Cheapest production MVP: tryon-v1.6. Premium seller/catalog output: tryon-max.
FASHN_MODEL_NAME=tryon-v1.6

# Optional fallback provider. Requires a model/version that accepts
# model_image and garment_image inputs.
REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=

TRYON_PORT=8787
TRYON_CACHE_DIR=server/cache
TRYON_UPLOAD_DIR=server/uploads
TRYON_TIMEOUT_MS=180000
